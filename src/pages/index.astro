---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StageFilter from '../components/StageFilter.astro';
import ArticleCard from '../components/ArticleCard.astro';

// Ordinal — earliest article = №01. Display newest-first.
const all = await getCollection('articles');
const byDateAsc = [...all].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const ordinalByIdAsc = new Map(byDateAsc.map((article, idx) => [article.id, idx + 1]));
const byDateDesc = [...all].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const countPadded = String(all.length).padStart(2, '0');
const volLabel = new Intl.DateTimeFormat('en-GB', { month: 'short', year: 'numeric' }).format(new Date());
---
<BaseLayout title="nvidia-learn — field notes on the DGX Spark">
  <header class="masthead">
    <div class="masthead__strip" aria-hidden="true">
      <span>Vol. 01</span>
      <span class="masthead__rule"></span>
      <span>nvidia-learn</span>
      <span class="masthead__rule"></span>
      <span>{volLabel}</span>
    </div>
    <h1 class="masthead__title">Field notes on the <em>DGX&nbsp;Spark</em>.</h1>
    <p class="masthead__tagline">
      One builder maximising the DGX Spark as a personal AI power user and edge AI rig.
      Every article is a session transcript turned into a deep-dive essay.
    </p>
    <div class="masthead__byline" aria-hidden="true">
      <span><span class="masthead__count">{countPadded}</span> articles published</span>
      <span class="masthead__rule"></span>
      <span>Apache 2.0 · by Manav Sehgal</span>
    </div>
  </header>

  <StageFilter current={null} />

  <section class="research-list">
    {byDateDesc.length === 0 ? (
      <p class="research-list__empty">No entries yet.</p>
    ) : (
      <>
        {byDateDesc.map((article) => (
          <ArticleCard article={article} ordinal={ordinalByIdAsc.get(article.id)!} />
        ))}
        <div class="research-list__closer">
          <span class="research-list__closer-glyph">※</span>
          <span>More articles in preparation</span>
          <span class="research-list__closer-rule"></span>
          <span>End of Vol. 01</span>
        </div>
      </>
    )}
  </section>
</BaseLayout>
