---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeasibilityBadge from '../../components/FeasibilityBadge.astro';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';
import { marked } from 'marked';

const REPO_ROOT = process.cwd();

export async function getStaticPaths() {
  const dataPath = join(process.cwd(), 'src', 'data', 'papers.json');
  if (!existsSync(dataPath)) return [];
  const payload = JSON.parse(readFileSync(dataPath, 'utf-8'));
  return (payload.papers || []).map((p: any) => ({
    params: { arxiv_id: p.arxiv_id },
    props: { paper: p },
  }));
}

const { paper } = Astro.props as { paper: any };

let evalHtml: string | null = null;
let evalText: string | null = null;
if (paper.deep_eval?.path) {
  const evalFile = join(REPO_ROOT, paper.deep_eval.path);
  if (existsSync(evalFile)) {
    evalText = readFileSync(evalFile, 'utf-8');
    evalHtml = await marked.parse(evalText);
  }
}

const verdict = paper.deep_eval?.verdict || paper.classify?.fast_verdict || 'unevaluated';
const stage = paper.classify?.suggested_stage || 'unsorted';
const series = paper.classify?.suggested_series || null;
const tags = paper.classify?.topic_tags || [];
const stack = paper.classify?.nvidia_stack || [];
const repos = paper.repos || [];
const promoted = paper.promoted_to || null;
---
<BaseLayout title={`${paper.title} — Frontier Scout`} description={paper.abstract.slice(0, 200)}>
  <article class="paper-detail">
    <header class="paper-detail__head">
      <p class="paper-detail__crumb">
        <a href={`${import.meta.env.BASE_URL}papers/`.replace(/\/+/g, '/')}>← All papers</a>
      </p>
      <p class="paper-detail__id">arXiv:{paper.arxiv_id} · <a href={paper.abs_url} target="_blank" rel="noopener">abstract</a> · <a href={paper.pdf_url} target="_blank" rel="noopener">pdf</a>{paper.hf_paper_url && <> · <a href={paper.hf_paper_url} target="_blank" rel="noopener">huggingface</a></>}</p>
      <h1 class="paper-detail__title">{paper.title}</h1>
      {paper.authors?.length > 0 && <p class="paper-detail__authors">{paper.authors.slice(0, 6).join(', ')}{paper.authors.length > 6 ? ' et al.' : ''}</p>}
      <div class="paper-detail__meta">
        <FeasibilityBadge verdict={verdict} evaluated={!!paper.deep_eval} />
        <span><strong>Popularity</strong> {paper.popularity_score ?? 0}</span>
        {paper.hf_upvotes != null && <span><strong>HF upvotes</strong> {paper.hf_upvotes}</span>}
        {paper.citations != null && <span><strong>Citations</strong> {paper.citations}</span>}
        {paper.published && <span><strong>Published</strong> {paper.published.slice(0, 10)}</span>}
        {paper.primary_category && <span><strong>Category</strong> {paper.primary_category}</span>}
      </div>
    </header>

    <section class="paper-detail__abstract">
      <h2>Abstract</h2>
      <p>{paper.abstract}</p>
    </section>

    <section class="paper-detail__classify">
      <h2>Frontier Scout classification</h2>
      <dl>
        <dt>Suggested stage</dt><dd>{stage}</dd>
        {series && <><dt>Suggested series</dt><dd>{series}</dd></>}
        {tags.length > 0 && <><dt>Topics</dt><dd>{tags.join(' · ')}</dd></>}
        {stack.length > 0 && <><dt>NVIDIA stack</dt><dd>{stack.join(' · ')}</dd></>}
        {paper.classify?.relevance_score != null && <><dt>Relevance to ai-field-notes</dt><dd>{paper.classify.relevance_score.toFixed(2)}</dd></>}
        {paper.classify?.one_line_rationale && <><dt>Fast verdict rationale</dt><dd>{paper.classify.one_line_rationale}</dd></>}
      </dl>
    </section>

    {repos.length > 0 && (
      <section class="paper-detail__repos">
        <h2>Linked repos</h2>
        <ul>
          {repos.map((r: any) => (
            <li>
              <a href={r.url} target="_blank" rel="noopener">{r.url.replace('https://github.com/', '')}</a>
              {' · '}
              {r.stars != null && <>★ {r.stars}</>}
              {r.forks != null && <> · {r.forks} forks</>}
              {r.last_commit && <> · last commit {r.last_commit.slice(0, 10)}</>}
              {r.language && <> · {r.language}</>}
              {r.archived && <> · <strong>archived</strong></>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {evalHtml ? (
      <section class="paper-detail__eval prose">
        <h2>Deep evaluation</h2>
        <p class="paper-detail__eval-meta">
          {paper.deep_eval?.evaluated_at && <span>Evaluated {paper.deep_eval.evaluated_at.slice(0, 10)}</span>}
        </p>
        <div set:html={evalHtml} />
      </section>
    ) : (
      <section class="paper-detail__eval-empty">
        <h2>Deep evaluation</h2>
        <p>This paper hasn't been deeply evaluated yet. Run the evaluator on the Spark:</p>
        <pre><code>npm run papers:eval -- {paper.arxiv_id}</code></pre>
        <p>The agent will fetch the paper body, survey the linked repo, consult the curated DGX Spark capability map, and produce a structured verdict (hypothesis → memory budget → NVIDIA-stack recipe → blockers → article-shape suggestion).</p>
      </section>
    )}

    {!promoted && evalHtml && (
      <section class="paper-detail__promote">
        <h2>Promote to article</h2>
        <p>If this is the next deep-dive, scaffold an article folder + evidence bundle:</p>
        <pre><code>npm run papers:promote -- {paper.arxiv_id}</code></pre>
        <p>This drops a <code>seed.md</code> + <code>evidence/</code> into <code>articles/&lt;slug&gt;/</code>, then you continue with <code>/tech-writer</code> as you would for any other article.</p>
      </section>
    )}

    {promoted && (
      <section class="paper-detail__promoted">
        <h2>Promoted</h2>
        <p>This paper has been promoted to article: <strong>{promoted.article_slug}</strong> ({promoted.status}).</p>
      </section>
    )}
  </article>

  <style>
    .paper-detail {
      max-width: 64rem;
      margin: 2rem auto 4rem;
      padding: 0 var(--page-px, 1.5rem);
    }
    .paper-detail__crumb { font-family: var(--font-mono); font-size: 0.8rem; }
    .paper-detail__crumb a { color: inherit; text-decoration: none; }
    .paper-detail__crumb a:hover { text-decoration: underline; }
    .paper-detail__id {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.04em;
      color: color-mix(in oklch, var(--ink) 65%, var(--paper));
      margin: 0.5rem 0;
    }
    .paper-detail__id a { color: inherit; }
    .paper-detail__title {
      font-family: var(--font-serif, var(--font-sans));
      font-size: 1.85rem;
      line-height: 1.22;
      margin: 0.4rem 0 0.6rem;
    }
    .paper-detail__authors {
      font-style: italic;
      color: color-mix(in oklch, var(--ink) 70%, var(--paper));
      margin: 0 0 0.8rem;
    }
    .paper-detail__meta {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 1rem;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: color-mix(in oklch, var(--ink) 70%, var(--paper));
    }
    .paper-detail__abstract,
    .paper-detail__classify,
    .paper-detail__repos,
    .paper-detail__eval,
    .paper-detail__eval-empty,
    .paper-detail__promote,
    .paper-detail__promoted {
      margin-top: 2rem;
      padding-top: 1.4rem;
      border-top: 1px solid var(--rule);
    }
    .paper-detail h2 {
      font-family: var(--font-serif, var(--font-sans));
      font-size: 1.2rem;
      margin: 0 0 0.7rem;
    }
    .paper-detail__abstract p {
      font-size: 1rem;
      line-height: 1.65;
    }
    .paper-detail__classify dl {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: 0.45rem 1.2rem;
      margin: 0;
      font-size: 0.92rem;
    }
    .paper-detail__classify dt {
      font-weight: 600;
      color: color-mix(in oklch, var(--ink) 75%, var(--paper));
    }
    .paper-detail__classify dd { margin: 0; }
    .paper-detail__repos ul { padding-left: 1rem; line-height: 1.7; }
    .paper-detail__repos a { color: inherit; }
    .paper-detail__promote pre,
    .paper-detail__eval-empty pre {
      background: color-mix(in oklch, var(--ink) 8%, transparent);
      padding: 0.6rem 0.8rem;
      border-radius: 4px;
      font-size: 0.88rem;
      overflow-x: auto;
    }
    .paper-detail__eval-meta {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: color-mix(in oklch, var(--ink) 60%, var(--paper));
      margin-bottom: 1rem;
    }
  </style>
</BaseLayout>
