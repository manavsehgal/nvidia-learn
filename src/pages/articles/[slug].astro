---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  const byDateAsc = [...all].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  const ordinalByIdAsc = new Map(byDateAsc.map((article, idx) => [article.id, idx + 1]));

  return all.map((article) => ({
    params: { slug: article.id },
    props: { article, ordinal: ordinalByIdAsc.get(article.id)! },
  }));
}

const { article, ordinal } = Astro.props;
const { Content } = await render(article);
const { title, date, author, product, stage, difficulty, time_required, hardware, summary } = article.data;

const ordinalLabel = `No. ${String(ordinal).padStart(3, '0')}`;
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);

const homeHref = import.meta.env.BASE_URL.replace(/\/+$/, '/') || '/';
---
<BaseLayout title={`${title} — nvidia-learn`} description={summary}>
  <article class="article">
    <a class="back-link" href={homeHref}>← nvidia-learn</a>

    <header class="article__header">
      <dl class="article__marginalia">
        <dt>Entry</dt>
        <dd>{ordinalLabel}</dd>
        <dt>Published</dt>
        <dd>{dateFmt}</dd>
        <dt>Stage</dt>
        <dd>{stage}</dd>
        <dt>Difficulty</dt>
        <dd>{difficulty}</dd>
        <dt>Time</dt>
        <dd>{time_required}</dd>
        <dt>Hardware</dt>
        <dd>{hardware}</dd>
        <dt>Author</dt>
        <dd>{author}</dd>
      </dl>
      <div class="article__header-body">
        <span class="article__ordinal">{ordinalLabel} · {product}</span>
        <h1 class="article__title">{title}</h1>
        <p class="article__summary">{summary}</p>
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
