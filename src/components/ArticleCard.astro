---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  ordinal: number;
}

const { article, ordinal } = Astro.props;
const { title, date, stage, product, time_required, summary } = article.data;

const ordinalLabel = `№${String(ordinal).padStart(2, '0')}`;
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);

const href = `${import.meta.env.BASE_URL}articles/${article.id}/`.replace(/\/+/g, '/');
---
<a class="card" href={href} aria-label={`${ordinalLabel}: ${title}`}>
  <span class="card__ordinal" aria-hidden="true">{ordinalLabel}</span>
  <div class="card__body">
    <div class="card__meta">
      <span>{stage}</span>
      <span>{product}</span>
      <time datetime={date.toISOString().slice(0, 10)}>{dateFmt}</time>
      <span>{time_required}</span>
    </div>
    <h2 class="card__title">{title}</h2>
    <p class="card__summary">{summary}</p>
  </div>
</a>
