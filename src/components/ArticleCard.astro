---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  ordinal: number;
}

const { article, ordinal } = Astro.props;
const { title, date, stage, difficulty, time_required, tags, summary } = article.data;

const ordinalLabel = `No. ${String(ordinal).padStart(3, '0')}`;
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);

// Limit tags on a card to three so the meta line doesn't wrap into a paragraph
const displayTags = tags.slice(0, 3).join(' · ');

const href = `${import.meta.env.BASE_URL}articles/${article.id}/`.replace(/\/+/g, '/');
---
<a class="card" href={href} aria-label={`${ordinalLabel}: ${title}`}>
  <aside class="card__marginalia">
    <span class="card__ordinal">{ordinalLabel}</span>
    <time class="card__date" datetime={date.toISOString().slice(0, 10)}>{dateFmt}</time>
  </aside>
  <div class="card__body">
    <span class="card__stage">{stage}</span>
    <h2 class="card__title">{title}</h2>
    <p class="card__summary">{summary}</p>
    <div class="card__meta">
      <span class="card__time">{time_required}</span>
      <span class="card__difficulty">{difficulty}</span>
      {displayTags && <span class="card__tags">{displayTags}</span>}
    </div>
  </div>
</a>
