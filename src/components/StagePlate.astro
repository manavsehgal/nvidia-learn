---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

interface Props {
  stage: string;
  title: string;
  blurb: string;
  entries: Array<{ article: CollectionEntry<'articles'>; ordinal: number }>;
}

const { stage, title, blurb, entries } = Astro.props;
const stageHref = `${import.meta.env.BASE_URL}stage/${stage}/`.replace(/\/+/g, '/');
const entryCount = entries.length;
---
<section class="stage-plate" id={`stage-${stage}`}>
  <header class="stage-plate__heading">
    <h2 class="stage-plate__title">{title}</h2>
    {entryCount > 0 && (
      <a class="stage-plate__stage-link" href={stageHref}>
        all {entryCount} entr{entryCount === 1 ? 'y' : 'ies'} →
      </a>
    )}
  </header>
  <p class="stage-plate__blurb">{blurb}</p>

  {entries.length === 0 ? (
    <p class="stage-plate__empty">No entries yet — planned.</p>
  ) : (
    entries.map(({ article, ordinal }) => (
      <ArticleCard article={article} ordinal={ordinal} />
    ))
  )}
</section>
